// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// No more "schemas" property! Prisma is now blind to the "auth" schema.
datasource db {
  provider = "postgresql"
}

// No more "@@schema"
enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

// No more "@@schema"
model User {
  id        String   @id @db.Uuid
  email     String?  @unique
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime? @updatedAt @db.Timestamptz

  teaching TeacherStudent[] @relation("Teacher")
  learning TeacherStudent[] @relation("Student")

  taughtLessons   Lesson[] @relation("TaughtLessons")
  receivedLessons Lesson[] @relation("ReceivedLessons")

  conversations Conversation[]
  sentMessages  ChatMessage[]

  @@map("users")
}

// No more "@@schema"
model TeacherStudent {
  teacherId String @db.Uuid
  teacher   User   @relation("Teacher", fields: [teacherId], references: [id], onDelete: Cascade)

  studentId String @db.Uuid
  student   User   @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)

  @@id([teacherId, studentId])
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  content   String?
  price     Float    @default(0)
  isPaid    Boolean  @default(false)

  // --- NEW SCHEDULING FIELDS ---
  scheduledAt DateTime? // Optional, as not all lessons might be scheduled yet
  duration    Int       @default(60) // Duration in minutes, default to 1 hour

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherId String @db.Uuid
  teacher   User   @relation("TaughtLessons", fields: [teacherId], references: [id], onDelete: Cascade)

  studentId String @db.Uuid
  student   User   @relation("ReceivedLessons", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

// No more "@@schema"
model Conversation {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  participants  User[]
  messages      ChatMessage[]

  @@map("conversations")
}

// No more "@@schema"
model ChatMessage {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())

  senderId       String       @db.Uuid
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}